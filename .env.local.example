NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCT_NAME=Secret Millionaire Society

# Local preview without login (remove before production)
DEV_BYPASS_AUTH=true
# Required for deploy/DB when using dev bypass — from Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

WEBHOOK_SIGNUP_URL=

# --- Blog Builder feature ---
RAPIDAPI_KEY=
RAPIDAPI_HOST=chatgpt-42.p.rapidapi.com
# Image generation host (used only when no Pixabay stock photo is found).
# ultra-fast-nano-banana-22.p.rapidapi.com — async POST index.php + GET poll (our code's path)
# google-nano-banana4.p.rapidapi.com — legacy /txt-to-img path (NOT compatible: returns 404)
RAPIDAPI_IMAGE_HOST=ultra-fast-nano-banana-22.p.rapidapi.com
# Optional — only if Ultra Fast playground uses different paths/query keys
# RAPIDAPI_IMAGE_CREATE_PATH=index.php
# RAPIDAPI_IMAGE_OUTPUT_PATH=index.php
# RAPIDAPI_IMAGE_OUTPUT_QUERY=id

# Free stock images (tried FIRST, before AI generation — much faster).
# Get a free key at https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Bulk generation concurrency pool size (default 3 — parallel GPT calls per deploy batch).
# TEXT_GENERATION_CONCURRENCY=3

SCRAPER_API_KEY=
